ScreenGui.Clear.MouseButton1Click:Connect(function()
    ScreenGui.codebox.Text = ""
end)

--------------------------------------------------
-- EXECUTE FUNCTION (SEM DESTRUIR A GUI)
--------------------------------------------------
ScreenGui.Execute.MouseButton1Click:Connect(function()
    local text = ScreenGui.codebox.Text
    if text == "" then
        warn("No code entered.")
        return
    end
    
    local success, err = pcall(function()
        local func = loadstring(text)
        if func then
            func()
        else
            error("Failed to load code")
        end
    end)
    
    if not success then
        warn("Execution Error: " .. tostring(err))
    end
end)

