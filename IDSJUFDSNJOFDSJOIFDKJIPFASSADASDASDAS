--------------------------------------------------
-- DRAG SYSTEMS (mantidos iguais)
--------------------------------------------------
local dragging = false
local dragInput
local dragStart
local startPos

local function update(input)
    local delta = input.Position - dragStart
    ScreenGui.Frame.Position = UDim2.new(
        startPos.X.Scale,
        startPos.X.Offset + delta.X,
        startPos.Y.Scale,
        startPos.Y.Offset + delta.Y
    )
end

ScreenGui.dragframe.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = ScreenGui.Frame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

ScreenGui.dragframe.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement then
        dragInput = input
    end
end)

UIS.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        update(input)
    end
end)

-- Drag do botão OPEN
local minDragging = false
local minDragInput
local minDragStart
local minStartPos

local function updateMin(input)
    local delta = input.Position - minDragStart
    ScreenGui.MinimizedButton.Position = UDim2.new(
        minStartPos.X.Scale,
        minStartPos.X.Offset + delta.X,
        minStartPos.Y.Scale,
        minStartPos.Y.Offset + delta.Y
    )
end

ScreenGui.MinimizedButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        minDragging = true
        minDragStart = input.Position
        minStartPos = ScreenGui.MinimizedButton.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                minDragging = false
            end
        end)
    end
end)

ScreenGui.MinimizedButton.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement then
        minDragInput = input
    end
end)

UIS.InputChanged:Connect(function(input)
    if input == minDragInput and minDragging then
        updateMin(input)
    end
end)
